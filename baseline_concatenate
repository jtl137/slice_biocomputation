import numpy as np
from scipy.signal import butter, filtfilt, decimate

# Define low-pass filter function
def LP_IIR(data, cutoff, fs, order=3):
    b, a = butter(order, cutoff / (0.5 * fs), btype='low')
    return filtfilt(b, a, data)

# Parameters
fs = 30000  # Original sampling rate (Hz)
cutoff1_LFP = 300  # Cutoff for low-pass filter
order = 3
downsample_factor = 15  # To reduce from 30kHz to 2kHz

# Allocate arrays for downsampled data
No_of_Channels = concatenated_data.shape[0]
filtered_length = concatenated_data.shape[1] // downsample_factor
concatenated_signal_low_pass_ds = np.zeros((No_of_Channels, filtered_length))

# Process each channel
for N in range(No_of_Channels):
    # Step 1: Low-pass filter
    filtered_signal = LP_IIR(concatenated_data[N, :], cutoff1_LFP, fs, order)

    # Step 2: Downsample with anti-aliasing handled by our own LP filter
    decimated_signal = decimate(filtered_signal, downsample_factor, ftype='fir', zero_phase=True)

    # Step 3: Handle any rounding differences
    trimmed_length = min(filtered_length, len(decimated_signal))
    concatenated_signal_low_pass_ds[N, :trimmed_length] = decimated_signal[:trimmed_length]
    
